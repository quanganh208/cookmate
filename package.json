{
  "name": "cookmate",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "docker compose up -d mongodb && pnpm backend",
    "backend": "cd backend && ./mvnw spring-boot:run",
    "backend:test": "cd backend && ./mvnw clean verify",
    "mobile": "pnpm --filter mobile start",
    "mobile:prebuild": "pnpm --filter mobile prebuild",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:ios": "pnpm --filter mobile ios",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "prettier": "^3.2.0",
    "typescript-eslint": "^8.57.1"
  }
}
