# ============================================================================
# Cookmate — unified env file (single source of truth for backend + mobile)
# Copy to .env and fill in real values.
# Mobile loads this via apps/mobile/app.config.js (inline parser at Expo startup).
# Backend loads this via scripts/run-mvnw.js before spawning the JVM.
# ============================================================================

# === Backend-only secrets (NEVER prefix with EXPO_PUBLIC_) ===
MONGODB_URI=mongodb://localhost:27017/cookmate
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
JWT_SECRET=dev-jwt-secret-must-be-at-least-64-characters-long-for-hmac-sha512-signing

# Gmail SMTP for password reset emails — backend only
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account)
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
MAIL_FROM=noreply@cookmate.app
MAIL_FROM_NAME=Cookmate

# === Shared (both backend Spring and Expo read these) ===
# API key — backend validates X-API-Key header, mobile sends it in every request
EXPO_PUBLIC_API_KEY=dev-api-key-change-in-production

# Google OAuth web client ID — backend verifies token audience, mobile requests with it
# Create at https://console.cloud.google.com/apis/credentials → OAuth client ID → Web application
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# === Mobile-only (frontend) ===
# Use http://localhost:8080/api for simulator/emulator,
# or your dev machine's LAN IP for a real device (e.g. http://192.168.1.10:8080/api)
EXPO_PUBLIC_API_URL=http://localhost:8080/api

# iOS native client ID for Google Sign-In
# Create at https://console.cloud.google.com/apis/credentials → OAuth client ID → iOS
# Bundle ID: com.cookmate.app
# Also update `iosUrlScheme` in apps/mobile/app.config.js with the reversed client ID
# (format: com.googleusercontent.apps.<client-id-without-suffix>)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# === Android Google Sign-In — no env var needed ===
# Just register an OAuth Android client in Google Cloud Console:
#   Application type: Android
#   Package name: com.cookmate.app
#   SHA-1: get with `keytool -list -v -keystore ~/.android/debug.keystore \
#     -alias androiddebugkey -storepass android -keypass android | grep SHA1`
# Google Sign-In SDK auto-resolves at runtime via package + SHA-1.
