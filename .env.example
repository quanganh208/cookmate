# MongoDB
MONGODB_URI=mongodb://localhost:27017/cookmate

# Spring Boot
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# API Key (required for all requests via X-API-Key header)
API_KEY=dev-api-key-change-in-production

# JWT
JWT_SECRET=dev-jwt-secret-must-be-at-least-64-characters-long-for-hmac-sha512-signing

# Google OAuth
GOOGLE_CLIENT_ID=
